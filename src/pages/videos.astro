---
import BaseLayout from "@layouts/BaseLayout.astro";
import { formatDate } from "@js/textUtils"; // Assuming this handles ISO strings or Date objects
import { Icon } from "astro-icon/components";

const API_KEY = import.meta.env.YOUTUBE_API_KEY;
const CHANNEL_ID = "UCQAyXZiV38qM5CmnYYonCfQ"; 

// 1. Fetch the "Uploads" playlist ID
const channelRes = await fetch(
  `https://www.googleapis.com/youtube/v3/channels?part=contentDetails&id=${CHANNEL_ID}&key=${API_KEY}`
);
const channelData = await channelRes.json();
const uploadsPlaylistId = channelData.items[0].contentDetails.relatedPlaylists.uploads;

// 2. Fetch videos from playlist
const playlistRes = await fetch(
  `https://www.googleapis.com/youtube/v3/playlistItems?part=snippet,contentDetails&maxResults=50&playlistId=${uploadsPlaylistId}&key=${API_KEY}`
);
const playlistData = await playlistRes.json();
const videoIds = playlistData.items.map(item => item.contentDetails.videoId).join(',');

// 3. Get detailed stats
const statsRes = await fetch(
  `https://www.googleapis.com/youtube/v3/videos?part=statistics,snippet&id=${videoIds}&key=${API_KEY}`
);
const statsData = await statsRes.json();

// 4. Sort by views (Descending)
const topVideos = statsData.items
  .sort((a, b) => parseInt(b.statistics.viewCount) - parseInt(a.statistics.viewCount))
  .slice(0, 6);
---

<BaseLayout title="Most Popular Videos" description="Popular videos from Ringgit Realms">
    <div class="mx-auto max-w-7xl px-4 pt-24 md:pt-36">
        <div class="text-center">
            <h1 class="h1">Most Popular Videos</h1>
            <hr class="bg-primary-600/50 mx-auto mt-4 max-w-[30%] rounded-full border-none pt-1" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
            {topVideos.map((video) => (
                <a
                    href={`https://www.youtube.com/watch?v=${video.id}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Watch ${video.snippet.title}`}
                    class="primary-focus group flex flex-col max-w-lg md:max-w-full mx-auto p-2 border border-base-200 shadow-md rounded-lg transition-transform duration-300 hover:scale-[1.02]"
                >
                    <div>
                        <div class="overflow-hidden rounded-md border border-base-100 shrink-0 justify-center sm:justify-normal">
                            <figure class="relative aspect-video overflow-hidden">
                                <img 
                                    src={video.snippet.thumbnails.high.url} 
                                    alt={`thumbnail for ${video.snippet.title}`}
                                    class="aspect-video w-full object-cover transition-transform duration-500 group-hover:scale-105"
                                    loading="lazy"
                                />
                            </figure>
                        </div>
                    </div>

                    <div class="w-full px-1">
                        <div class="mt-3 flex w-full flex-wrap justify-between items-center gap-2">
                            <div class="flex items-center gap-1 text-sm opacity-80">
                                <Icon name="tabler:eye" class="h-4 w-4" />
                                <span class="font-medium">
                                    {Number(video.statistics.viewCount).toLocaleString()} views
                                </span>
                            </div>

                            <div class="text-xs opacity-70 md:text-sm">
                                <div class="flex items-center gap-1">
                                    <Icon name="tabler:calendar-event" class="h-3.5 w-3.5" />
                                    <p class="whitespace-nowrap">
                                        <time datetime={video.snippet.publishedAt}>
                                            {formatDate(new Date(video.snippet.publishedAt))}
                                        </time>
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="mt-2">
                            <h2 class="group-hover:text-primary-600 line-clamp-2 text-lg font-semibold transition duration-300 md:text-xl">
                                {video.snippet.title}
                            </h2>
                        </div>

                        <p class="mt-2 line-clamp-2 text-sm opacity-70">
                            {video.snippet.description}
                        </p>
                    </div>
                </a>
            ))}
        </div>
    </div>
</BaseLayout>